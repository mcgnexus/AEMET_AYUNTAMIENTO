# AEMET OpenData (obligatorio)
AEMET_API_KEY=

# Open-Meteo (opcional, por defecto endpoints públicos)
AEMET_OBSERVATION_URL=
AEMET_TIMEOUT_MS=4000
AEMET_MAX_ATTEMPTS=2
AEMET_RETRY_DELAY_MS=350
AEMET_CACHE_MAX_AGE_MINUTES=240
AEMET_REFRESH_INTERVAL_MS=900000
AEMET_FAILURE_COOLDOWN_MS=600000
AEMET_RATE_LIMIT_COOLDOWN_MS=900000

# Sentinel Hub (opcional, para cobertura satelital)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# Neon PostgreSQL (obligatorio para persistencia)
DATABASE_URL=
NEON_DATABASE_URL=

# Administración (obligatorio para acceder a /admin)
CRON_SECRET=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
